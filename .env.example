# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key
LLM_MODEL=gpt-4o
WEB_SEARCH_MODEL=gpt-4.1
EMBEDDING_MODEL=text-embedding-3-small

# Server Configuration
HOST=0.0.0.0
PORT=8001

# Session Management
SESSION_STORAGE_PATH=./conversation_sessions
MAX_SESSIONS=100
MAX_TOKENS_PER_SESSION=100000

# Logging
LOG_LEVEL=INFO
LOG_TO_FILE=false
LOG_FILE_PATH=./logs/app.log

# Index Storage
INDEX_ROOT=./index

# S3 Storage (optional — set STORAGE_BACKEND=s3 to enable)
STORAGE_BACKEND=local
S3_BUCKET_NAME=
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_AGENT_PREFIX=rag-agent
